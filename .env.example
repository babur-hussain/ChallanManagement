# ═══════════════════════════════════════════════════════════════
# TextilePro Environment Variables
# Copy this file to .env.development and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────
NODE_ENV=development                    # development | staging | production
PORT=3001                               # API server port
LOG_LEVEL=debug                         # error | warn | info | http | debug

# ─── MongoDB ─────────────────────────────────────────────────
# For local Docker: mongodb://localhost:27017/textilepro?replicaSet=rs0
# For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/textilepro
MONGODB_URI=mongodb://localhost:27017/textilepro?replicaSet=rs0

# ─── Redis ───────────────────────────────────────────────────
# For local Docker: redis://localhost:6379
# For production: redis://:password@host:port
REDIS_URL=redis://localhost:6379

# ─── Firebase Admin SDK (Backend) ───────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# Alternative: path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ─── Firebase Client SDK (Frontend — VITE_ prefix required) ──
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── AWS S3 ──────────────────────────────────────────────────
# For local Docker (LocalStack): use test/test credentials
# For production: create IAM user with S3 access
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=ap-south-1
AWS_S3_BUCKET=textilepro-uploads
AWS_S3_ENDPOINT=http://localhost:4566   # Remove for production (uses real AWS)

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-very-long-random-string-in-production-at-least-64-chars
JWT_EXPIRY=7d                           # Access token expiry
JWT_REFRESH_EXPIRY=30d                  # Refresh token expiry

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173      # Comma-separated list of allowed origins

# ─── Rate Limits ─────────────────────────────────────────────
RATE_LIMIT_GLOBAL_MAX=1000              # Requests per window per IP
RATE_LIMIT_GLOBAL_WINDOW_MS=900000      # 15 minutes in ms
RATE_LIMIT_AUTH_MAX=20                  # Auth requests per window per IP
RATE_LIMIT_AUTH_WINDOW_MS=900000        # 15 minutes in ms

# ─── External Services ──────────────────────────────────────
# WATI WhatsApp API
WATI_API_KEY=
WATI_API_URL=https://live-server-XXXXX.wati.io

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── SMTP (MailHog in dev, SES/SendGrid in prod) ────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false                       # true for port 465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@textilepro.in
SMTP_FROM_NAME=TextilePro

# ─── Sentry Error Tracking ──────────────────────────────────
SENTRY_DSN=

# ─── Plan Feature Flags ─────────────────────────────────────
PLAN_FEATURES={"BASIC":{"maxUsers":1,"features":["challans","parties"]},"STANDARD":{"maxUsers":3,"features":["challans","parties","invoices","fabric_master"]},"PROFESSIONAL":{"maxUsers":10,"features":["challans","parties","invoices","fabric_master","reports","brokers","inventory"]},"ENTERPRISE":{"maxUsers":-1,"features":["*"]}}
